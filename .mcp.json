{
  "mcpServers": {
    "test-suite-mcp": {
      "command": "node",
      "args": ["dist/index.js"],
      "cwd": "${workspaceFolder}",
      "env": {
        "BROWSER_TESTER_ROOT": "${workspaceFolder}"
      }
    },
    "playwright-test": {
      "command": "npx",
      "args": [
        "playwright",
        "run-test-mcp-server",
        "--config",
        "playwright.config.ts"
      ],
      "cwd": "${workspaceFolder}"
    }
  }
}
